# API Configuration
APP_NAME="Trellix API"
APP_VERSION="0.1.0"

# Database Configuration
# For Docker, use DB_HOST=db. For local, use DB_HOST=localhost
DB_HOST=db
DB_PORT=3306
DB_USER=trellix
DB_PASSWORD=trellix
DB_NAME=trellix

# Security
# Generate a real secret key using: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
